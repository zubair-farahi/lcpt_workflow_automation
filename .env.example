# ── CP Suite (TaskManager API) ───────────────────────────────────────────────
CP_SUITE_BASE_URL=https://cp3-staging.itscomply.com/task-manager-api
# OAuth2 password-grant identity server
CP_SUITE_IDENTITY_SERVER=https://stg-id.itscomply.com
CP_SUITE_GRANT_TYPE=password
CP_SUITE_CLIENT_ID=cp3Client
CP_SUITE_CLIENT_SECRET=
# A staging user must be provisioned by the CP Suite team (see AIP-388 thread)
CP_SUITE_USERNAME=
CP_SUITE_PASSWORD=
# Attachment endpoint params — CONFIRM with CP Suite before production use
CP_SUITE_FILE_CATEGORY=Document
CP_SUITE_USER_ID=

# ── HaulSafe OCR ─────────────────────────────────────────────────────────────
HAUL_OCR_BASE_URL=https://haul-safe-document-api-staging.haulwith.us
# Get from Keeper: "Haul OCR Service - Staging - API key"
HAUL_OCR_API_KEY=
HAUL_OCR_POLL_INTERVAL_SECONDS=5
HAUL_OCR_MAX_WAIT_SECONDS=120
HAUL_OCR_MAX_ATTEMPTS=24
# Set true only if HaulSafe confirms it returns confidence scores
REQUIRE_OCR_CONFIDENCE=false
OCR_CONFIDENCE_THRESHOLD=0.7

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
# Get AWS credentials from Keeper (scoped to fw-ocr-project bucket only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
LCPT_SCAN_BUCKET=fw-ocr-project

# S3 prefixes — all must end with /
LCPT_SCAN_INCOMING_PREFIX=incoming/
LCPT_SCAN_PROCESSING_PREFIX=processing/
LCPT_SCAN_PROCESSED_PREFIX=processed/
LCPT_SCAN_REVIEW_PREFIX=review/
LCPT_SCAN_FAILED_PREFIX=failed/

# Presigned URL expiry (seconds) for HaulSafe OCR access to cover-sheet PDF
# TODO: confirm HaulSafe can access presigned S3 URLs (open question)
S3_PRESIGNED_URL_EXPIRY_SECONDS=900

# ── Local storage (dev only) ──────────────────────────────────────────────────
LOCAL_STORAGE_DIR=./data
# Only needed if using local files with real HaulSafe OCR (not S3).
# Point to an ngrok tunnel or similar: LOCAL_STORAGE_BASE_URL=https://abc123.ngrok.io/files
LOCAL_STORAGE_BASE_URL=

# ── Review queue ──────────────────────────────────────────────────────────────
REVIEW_QUEUE_DIR=./review_queue

# ── Processing policies ───────────────────────────────────────────────────────
# "review" = route whole scan to human review when a checklist item is missing
# "skip"   = silently skip that checklist item and continue
MISSING_CHECKLIST_ITEM_POLICY=review
# Set true to block pipeline when company name doesn't match WR prefix mapping
COMPANY_PREFIX_VALIDATION_REQUIRED=false
# Regex for Work Request number validation (default matches e.g. PFG-WR-351)
WR_NUMBER_PATTERN=^[A-Z]{2,6}-WR-\d+$

# ── Config paths ──────────────────────────────────────────────────────────────
CHECKLIST_MAPPING_PATH=./config/checklist_mapping.yaml
COMPANY_PREFIX_MAPPING_PATH=./config/company_prefix_mapping.yaml
HAUL_OCR_FIELDS_PATH=./config/haul_ocr_fields.yaml

# ── Logging ───────────────────────────────────────────────────────────────────
# Set to "true" for JSON log output (Lambda / production)
JSON_LOGS=false
LOG_LEVEL=INFO

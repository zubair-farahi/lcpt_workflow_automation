# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored.

aws_region       = "us-east-1"
scan_bucket_name = "fw-ocr-project"
image_tag        = "latest"

# AWS CLI profile selection. Two patterns:
#
#   Option A — use whatever the default credential chain resolves to
#              (env vars, AWS_PROFILE, ~/.aws default, etc.):
#       aws_profile = null
#
#   Option B — force a specific named profile:
#       aws_profile = "lcpt-deploy"
#
# WARNING: this MUST be a profile with rights to create ECR, Lambda,
# IAM, CloudWatch Logs, Secrets Manager (and SQS once the trigger is
# enabled). Do NOT use a scoped S3-only profile such as "fw-ocr-s3" —
# Terraform will fail mid-apply and leave the stack half-created.
aws_profile = null

# Keep the S3 -> SQS -> Lambda trigger OFF until the bucket owner has
# explicitly approved enabling it. aws_s3_bucket_notification REPLACES
# the bucket's entire existing notification config (see trigger.tf).
enable_s3_trigger = false

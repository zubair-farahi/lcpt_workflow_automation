# ─────────────────────────────────────────────────────────────────────────────
# Secrets — NEVER commit these
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# Postman environments can contain api keys / passwords. Commit the COLLECTION
# but keep the environment files local. Remove this line if yours are clean.
*.postman_environment.json

